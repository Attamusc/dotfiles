{{- /* merge-mcp-json: merges public + private MCP server configs.
       Usage: template "merge-mcp-json" (dict "public" ".data/path/to/mcp.json" "private" ".data-private/path/to/mcp.json" "sourceDir" .chezmoi.sourceDir)
       - Public config is required (committed to git)
       - Private config is optional (gitignored in .data-private/)
       - Private servers override public ones with the same name */ -}}
{{- $public := include .public | mustFromJson -}}
{{- $publicServers := index $public "mcpServers" | default dict -}}
{{- $privatePath := joinPath .sourceDir .private -}}
{{- $mergedServers := $publicServers -}}
{{- if stat $privatePath -}}
{{-   $private := include .private | mustFromJson -}}
{{-   $privateServers := index $private "mcpServers" | default dict -}}
{{-   $mergedServers = merge $privateServers $publicServers -}}
{{- end -}}
{{ dict "mcpServers" $mergedServers | toPrettyJson }}
