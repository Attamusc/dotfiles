#!/bin/bash
## tmr - kill a tmux session. Works from within tmux too. (@bag-man)
# `tmr` will allow you to select your tmux session via tv.
# `tmr irc` will kill the irc session (if it exists).


if [ $1 ]; then
  tmux kill-session -t "$1" 2>/dev/null
else
  session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | tv --no-preview --no-remote) && tmux kill-session -t "$session" || echo "No sessions found."
fi
