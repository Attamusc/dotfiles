#!/bin/bash
#
# Chezmoi dotfiles pre-push hook.
#
# Blocks pushes that introduce private-only strings the user wants to keep out
# of public history. The actual patterns are loaded at runtime from
# ~/.local/share/chezmoi-hooks/pattern (one literal substring per line,
# # comments and blank lines ignored). That file is rendered by chezmoi from
# .data-private/chezmoi-hooks/pattern (gitignored) so the patterns themselves
# never appear in this tracked source tree.
#
# If the pattern file is absent or empty (e.g. fresh clone before private data
# is installed), the hook is a no-op.
#
# To bypass intentionally: git push --no-verify (or jj git push --no-verify).

set -uo pipefail

PATTERN_FILE="${HOME}/.local/share/chezmoi-hooks/pattern"
NULL_SHA='0000000000000000000000000000000000000000'

# Load patterns. Empty / missing file -> hook is a no-op.
if [ ! -f "$PATTERN_FILE" ] ; then
  exit 0
fi

PATTERNS=()
while IFS= read -r line || [ -n "$line" ] ; do
  case "$line" in
    ''|\#*) continue ;;
    *) PATTERNS+=("$line") ;;
  esac
done < "$PATTERN_FILE"

if [ ${#PATTERNS[@]} -eq 0 ] ; then
  exit 0
fi

found=0

while read -r local_ref local_sha remote_ref remote_sha ; do
  [ "$local_sha" = "$NULL_SHA" ] && continue

  if [ "$remote_sha" = "$NULL_SHA" ] ; then
    range_args="$local_sha --not --remotes=origin"
  else
    range_args="${remote_sha}..${local_sha}"
  fi

  # For each configured pattern, walk every commit in the range and print
  # added lines containing the pattern, attributed to their commit.
  # Exclude the hook's own source directory and the run_once installer so
  # references to "patterns" in shipped code never self-trigger. Any future
  # file that legitimately needs to reference patterns should be added to
  # this exclusion list.
  for pattern in "${PATTERNS[@]}" ; do
    hits=$(git log $range_args -p --reverse \
             --pretty=format:'__COMMIT__ %h %s' \
             -- \
               ':!dot_local/share/chezmoi-hooks/' \
               ':!run_once_after_install-chezmoi-pre-push-hook.sh.tmpl' \
             2>/dev/null | \
           awk -v re="$pattern" '
             /^__COMMIT__/ { commit = substr($0, 12) }
             /^\+/ && !/^\+\+\+/ && index($0, re) {
               if (!printed[commit]++) { print ""; print "  commit: " commit }
               print "    " $0
             }
           ')

    if [ -n "$hits" ] ; then
      if [ $found -eq 0 ] ; then
        echo "" >&2
        echo "🚨 pre-push hook: private-only pattern detected" >&2
        found=1
      fi
      echo "" >&2
      echo "  ref:     $local_ref → $remote_ref" >&2
      echo "  pattern: $pattern" >&2
      echo "$hits" >&2
    fi
  done
done

if [ $found -eq 1 ] ; then
  echo "" >&2
  echo "Push aborted. Options:" >&2
  echo "  1. Remove the offending content from the affected file(s)," >&2
  echo "     amend the commit(s), and re-push." >&2
  echo "  2. If you intend to push to a private-only remote, bypass" >&2
  echo "     with --no-verify." >&2
  echo "" >&2
  exit 1
fi

exit 0
